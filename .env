# =========================
# Application
# =========================
APP_NAME=MyAwesomeApp
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=your-super-secret-key-here
LOG_LEVEL=INFO

# =========================
# Database
# =========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=myapp_db
DB_USER=postgres
DB_PASSWORD=postgres123

DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/myapp_db

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =========================
# Authentication
# =========================
JWT_SECRET_KEY=jwt-super-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# =========================
# Email / SMTP
# =========================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=example@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
SMTP_SSL=false
MAIL_DEFAULT_SENDER=example@gmail.com

# =========================
# OpenAI
# =========================
OPENAI_API_KEY=sk-your-openai-api-key

# =========================
# Anthropic
# =========================
ANTHROPIC_API_KEY=sk-ant-your-api-key

# =========================
# Google Gemini
# =========================
GEMINI_API_KEY=your-gemini-api-key

# =========================
# GitHub
# =========================
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =========================
# AWS S3
# =========================
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=ap-south-1
AWS_S3_BUCKET=myapp-storage

# =========================
# Cloudinary
# =========================
CLOUDINARY_CLOUD_NAME=my-cloud
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=my-cloudinary-secret

# =========================
# OAuth
# =========================
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=google-client-secret

GITHUB_CLIENT_ID=github-client-id
GITHUB_CLIENT_SECRET=github-client-secret

# =========================
# Frontend
# =========================
FRONTEND_URL=http://localhost:3000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =========================
# Rate Limiting
# =========================
RATE_LIMIT_PER_MINUTE=100

# =========================
# File Uploads
# =========================
MAX_UPLOAD_SIZE_MB=25
UPLOAD_FOLDER=uploads

# =========================
# Celery / Background Jobs
# =========================
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =========================
# Monitoring
# =========================
SENTRY_DSN=https://example@sentry.io/1234567

# =========================
# Feature Flags
# =========================
ENABLE_SIGNUP=true
ENABLE_EMAIL_VERIFICATION=true
ENABLE_ANALYTICS=false

# =========================
# Misc
# =========================
TIMEZONE=Asia/Kolkata
